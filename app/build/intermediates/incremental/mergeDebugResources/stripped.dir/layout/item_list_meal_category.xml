<?xml version="1.0" encoding="utf-8"?>

                                                       
                                                   

    

                 
                          
                                                          

           
    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_margin="6dp"
        android:padding="@dimen/padding_8dp" android:tag="layout/item_list_meal_category_0" xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto" xmlns:tools="http://schemas.android.com/tools">

        <de.hdodenhof.circleimageview.CircleImageView
            android:id="@+id/item_image_meal"
            android:layout_width="64dp"
            android:layout_height="64dp"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:srcCompat="@drawable/ic_launcher_background"
            android:tag="binding_1"                       />

        <TextView
            android:id="@+id/item_text_meal_name"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:ellipsize="end"
            android:maxLines="2"
            android:layout_marginStart="@dimen/padding_8dp"
            android:textAppearance="@style/TextAppearance.AppCompat.Large"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toEndOf="@+id/item_image_meal"
            app:layout_constraintTop_toTopOf="@+id/item_image_meal"
            tools:text="Beef Banh Mi Bowls with Sriracha Mayo, Carrot"
            android:tag="binding_2"               />

    </androidx.constraintlayout.widget.ConstraintLayout>
         